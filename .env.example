# ---------------------------------------------------------------------------
# UniFi console connection
# ---------------------------------------------------------------------------
# Base URL of the UniFi console (UniFi OS: UDM/UDR/CloudKey Gen2, or a classic
# software controller). Include scheme, no trailing slash.
UNIFI_HOST=https://192.168.1.1

# Use a LOCAL admin account (UniFi: Admins & Users -> "Restrict to local access
# only"). A ui.com cloud account hits MFA and cannot log in from a script.
UNIFI_USERNAME=local-admin
UNIFI_PASSWORD=change-me

# Self-signed certs are the norm on local consoles; leave verification off
# unless you have a real cert. Set to true to enforce TLS verification.
UNIFI_VERIFY_TLS=false

# Restrict to specific site internal names (comma separated). Empty = all sites
# visible to the account.
UNIFI_SITES=

# How often (seconds) to poll the console for fresh live data.
POLL_INTERVAL_SECONDS=30

# Experimental: also subscribe to the controller's WebSocket event stream for
# near-instant client connect/disconnect/roam and AP up/down updates. The poll
# above stays on as the authoritative reconciler. Undocumented UniFi API.
WEBSOCKET_ENABLED=false

# ---------------------------------------------------------------------------
# Meraki-compatible facade
# ---------------------------------------------------------------------------
# The API key a client (e.g. a Hamina Live "Cisco Meraki" integration, or curl)
# must present in X-Cisco-Meraki-API-Key / Authorization: Bearer to read the
# Meraki-shaped endpoints. Generate a long random string.
MERAKI_COMPAT_API_KEY=replace-with-a-long-random-token

# Display name for the synthesized Meraki "organization".
MERAKI_ORG_NAME=UniFi

# ---------------------------------------------------------------------------
# Scheduled OpenIntent refresh (near-live re-import)
# ---------------------------------------------------------------------------
# Enable the background job that re-runs the exporter on an interval.
OPENINTENT_REFRESH_ENABLED=false

# Path to the companion exporter (unifi_export.py from shark-fi/unifi-hamina-export).
OPENINTENT_EXPORTER_PATH=../unifi-hamina-export/unifi_export.py

# Exporter mode and how often to regenerate the zip.
OPENINTENT_MODE=innerspace
OPENINTENT_REFRESH_SECONDS=900
OPENINTENT_OUTPUT_DIR=./exports

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8080

# ---------------------------------------------------------------------------
# Public exposure (optional) — Cloudflare Tunnel
# ---------------------------------------------------------------------------
# To reach the bridge from Hamina's cloud you need a public HTTPS endpoint.
# The `tunnel` docker compose profile runs cloudflared with this token; create
# a tunnel in the Cloudflare Zero Trust dashboard and paste its token here.
# See docs/EXPOSURE.md. Leave empty if you expose it another way.
CF_TUNNEL_TOKEN=
